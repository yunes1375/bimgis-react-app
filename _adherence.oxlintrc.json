{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/data/**",
              "components/display/**",
              "components/inputs/**",
              "components/layout/**",
              "components/patterns/**",
              "components/surfaces/**",
              "ui_kits/atlas/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Mono|Inter|Space Grotesk))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Mono, Inter, Space Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='AdjustRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|step|unit|format|onChange|key|ref|className|style|children)$/]",
        "message": "<AdjustRow> doesn't accept that prop. Declared props: label, value, step, unit, format, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='BasemapOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|swatchColor|swatchImage|key|ref|className|style|children)$/]",
        "message": "<BasemapOption> doesn't accept that prop. Declared props: id, label, swatchColor, swatchImage."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|loading|leftIcon|rightIcon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, loading, leftIcon, rightIcon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|subtitle|action|footer|dense|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, title, subtitle, action, footer, dense, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Column'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|header|align|width|sortable|render|key|ref|className|style|children)$/]",
        "message": "<Column> doesn't accept that prop. Declared props: key, header, align, width, sortable, render."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|action|className|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, description, action, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='FabPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|shape|icon|children|key|ref|className|style|children)$/]",
        "message": "<FabPill> doesn't accept that prop. Declared props: active, shape, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='FabPill'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:pill|circle)$/]",
        "message": "<FabPill> shape must be one of 'pill' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterSearch'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|count|onClear|filters|className|key|ref|className|style|children)$/]",
        "message": "<FilterSearch> doesn't accept that prop. Declared props: value, onChange, placeholder, count, onClear, filters, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|label|key|ref|className|style|children)$/]",
        "message": "<FooterLink> doesn't accept that prop. Declared props: href, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='GpsAccuracyBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:accuracy|level|className|hideValue|key|ref|className|style|children)$/]",
        "message": "<GpsAccuracyBadge> doesn't accept that prop. Declared props: accuracy, level, className, hideValue."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|fullWidth|addonEnd|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, fullWidth, addonEnd."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|tone|trend|className|key|ref|className|style|children)$/]",
        "message": "<KpiTile> doesn't accept that prop. Declared props: label, value, tone, trend, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='MobileDrawer'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|side|children|closeLabel|key|ref|className|style|children)$/]",
        "message": "<MobileDrawer> doesn't accept that prop. Declared props: open, onClose, title, side, children, closeLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='MobileDrawer'] > JSXAttribute[name.name='side'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<MobileDrawer> side must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|onClose|ghost|children|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, onClose, ghost, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='PasswordInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:showLabel|hideLabel|key|ref|className|style|children)$/]",
        "message": "<PasswordInput> doesn't accept that prop. Declared props: showLabel, hideLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|className|title|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: tone, dot, children, className, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|disabled|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteHeaderNavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|label|active|icon|key|ref|className|style|children)$/]",
        "message": "<SiteHeaderNavLink> doesn't accept that prop. Declared props: href, label, active, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|label|className|key|ref|className|style|children)$/]",
        "message": "<Spinner> doesn't accept that prop. Declared props: size, label, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Spinner'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Spinner> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StackedCardTable'] > JSXAttribute > JSXIdentifier[name!=/^(?:columns|rows|rowKey|empty|actions|className|key|ref|className|style|children)$/]",
        "message": "<StackedCardTable> doesn't accept that prop. Declared props: columns, rows, rowKey, empty, actions, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|count|disabled|content|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: value, label, count, disabled, content."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|fullWidth|mono|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, hint, error, fullWidth, mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|description|action|onClose|className|icon|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: tone, title, description, action, onClose, className, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: label, hint."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
